{
  "name": "memory-anchor",
  "version": "1.0.6",
  "description": "MemoryAnchor CLI scaffold",
  "license": "Apache-2.0",
  "author": "LAl4l4",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "anchor": "dist/cli.js"
  },
  "files": [
    "dist/",
    "tree-sitter-parser/",
    "README.md"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "start": "node dist/cli.js",
    "prepublishOnly": "npm run build",
    "test": "npm run build && node --experimental-vm-modules ./node_modules/jest/bin/jest.js"
  },
  "dependencies": {
    "cac": "^6.7.14",
    "glob": "^13.0.6",
    "web-tree-sitter": "0.26.9"
  },
  "devDependencies": {
    "tree-sitter-wasms": "^0.1.13",
    "@types/glob": "^8.1.0",
    "@types/node": "^20.14.12",
    "typescript": "^5.4.5",
    "jest": "^29.7.0"
  },
  "jest": {
    "testEnvironment": "node",
    "testMatch": [
      "<rootDir>/tests/**/*.test.js"
    ]
  },
  "engines": {
    "node": ">=18"
  },
  "compilerOptions": {
    "outDir": "./dist",
    "rootDir": "."
  }
}
